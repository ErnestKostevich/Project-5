# ──────────────────────────── Required ────────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: pin a different model
# ANTHROPIC_MODEL=claude-sonnet-4-5


# ──────────────────────────── Optional: Auth (Clerk) ────────────────────────────
# When both are set, the site shows Sign in / UserButton automatically.
# Get keys at https://dashboard.clerk.com/
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
# CLERK_SECRET_KEY=sk_test_xxxxx


# ──────────────────────────── Optional: Payments (Stripe) ────────────────────────────
# When all three are set, the "Subscribe" button in pricing becomes active.
# Get keys at https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_PRICE_ID_PRO_MONTHLY=price_xxxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Webhook secret (set after running `stripe listen`)
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Where Stripe should send the user after checkout (no trailing slash)
# NEXT_PUBLIC_APP_URL=http://localhost:3000


# ──────────────────────────── Optional: Tip Jar ────────────────────────────
# When set, a "Tip the maker" link appears in the footer.
# Use any URL — ko-fi, Buy Me a Coffee, PayPal, Patreon, GitHub Sponsors.
# NEXT_PUBLIC_TIP_JAR_URL=https://ko-fi.com/yourusername
