# ──────────────────────────── Required (in BYOK mode: optional) ────────────────────────────
# Set this ONLY if you want a server-paid free tier (3 generations/day for users
# without their own key). Leave commented for pure BYOK mode where users
# ALWAYS bring their own Anthropic key and you pay $0.
# Get your key at https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where the site lives (no trailing slash). Used for OAuth callbacks +
# payment success URLs. Vercel sets VERCEL_URL automatically but this
# value wins when present.
# NEXT_PUBLIC_APP_URL=https://your-domain.com


# ──────────────────────────── Payments — Option A: NOWPayments (NO KYC, crypto) ────────────────────────────
# Recommended for operators who don't want to do KYC. NOWPayments accepts
# 200+ cryptos, holds them, lets you withdraw to a wallet (no KYC for
# withdrawal). Subscription fee → user pays once for 30 days of Pro.
#
# Sign up at https://nowpayments.io  →  Account → Store settings → API keys
# NOWPAYMENTS_API_KEY=XXXXXXX-XXXXXXX-XXXXXXX-XXXXXXX

# Highly recommended — used to verify webhook signatures so attackers can't
# fake "payment received" events. Set the same value in NOWPayments dashboard
# → Account → IPN settings → IPN Secret Key.
# NOWPAYMENTS_IPN_SECRET=your-strong-secret

# Tell the client which provider is active (so the pricing CTA shows
# "Pay with crypto" instead of "Subscribe"). Match the chosen provider.
# NEXT_PUBLIC_PAYMENTS_PROVIDER=nowpayments


# ──────────────────────────── Payments — Option B: Stripe (requires KYC) ────────────────────────────
# Use if you prefer fiat / card payments and don't mind the Stripe verification.
# Get keys at https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_PRICE_ID_PRO_MONTHLY=price_xxxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Webhook secret (set after running `stripe listen`)
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx


# ──────────────────────────── Optional: Auth (Clerk) ────────────────────────────
# When both are set, the site shows Sign in / UserButton automatically.
# Get keys at https://dashboard.clerk.com/
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
# CLERK_SECRET_KEY=sk_test_xxxxx


# ──────────────────────────── Optional: Tip Jar ────────────────────────────
# When set, a "Tip the maker" link appears in the footer.
# Use any URL — ko-fi, Buy Me a Coffee, PayPal, Patreon, GitHub Sponsors.
# NEXT_PUBLIC_TIP_JAR_URL=https://ko-fi.com/yourusername
